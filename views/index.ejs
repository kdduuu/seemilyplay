<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>seemilyplay</title>

    <link rel="stylesheet"
          href="/css/style.css">

</head>

<body>


    <!-- ===================================== -->
    <!-- SCANLINES -->
    <!-- ===================================== -->

    <div class="scanlines"></div>


    <!-- ===================================== -->
    <!-- JANELA -->
    <!-- ===================================== -->

    <div class="browser-window">


        <!-- ===================================== -->
        <!-- TOPO -->
        <!-- ===================================== -->

        <div class="browser-top">


            <div class="window-buttons">

                <span></span>
                <span></span>
                <span></span>

            </div>


            <div class="window-title">

                emily navigator

            </div>

        </div>


        <!-- ===================================== -->
        <!-- MENU -->
        <!-- ===================================== -->

        <div class="menu-bar">

            <span>File</span>
            <span>Edit</span>
            <span>View</span>
            <span>Favorites</span>
            <span>Help</span>

        </div>


        <!-- ===================================== -->
        <!-- URL -->
        <!-- ===================================== -->

        <div class="url-bar">

            <span>URL:</span>

            <input type="text"
                   value="https://seemilyplay.net"
                   readonly>

        </div>


        <!-- ===================================== -->
        <!-- FRASE -->
        <!-- ===================================== -->

        <div class="top-quote">

            now we are all just here to see Emily play

        </div>


        <!-- ===================================== -->
        <!-- CONTEÚDO -->
        <!-- ===================================== -->

        <div class="main-content">


            <!-- ===================================== -->
            <!-- ESQUERDA -->
            <!-- ===================================== -->

            <div class="left-side">


                <!-- ===================================== -->
                <!-- GALERIA -->
                <!-- ===================================== -->

                <div class="window-box">

                    <div class="box-title">

                        webcam archive

                    </div>


                    <div class="gallery">


                        <!-- FOTO -->

                        <div class="photo-card">

                            <div class="photo-wrapper">

                                <img src="/photos/photo1.jpeg">

                                <div class="timestamp">

                                    02:14AM

                                </div>

                            </div>

                        </div>



                        <!-- FOTO -->

                        <div class="photo-card">

                            <div class="photo-wrapper">

                                <img src="/photos/photo2.jpeg">

                                <div class="timestamp">

                                    02:32AM

                                </div>

                            </div>

                        </div>


                    </div>

                </div>



                <!-- ===================================== -->
                <!-- CHAT -->
                <!-- ===================================== -->

                <div class="window-box">

                    <div class="box-title">

                        archived chatlogs

                    </div>


                    <div class="chat-area">


                        <div class="messages fake-chat">


                            <!-- MENSAGEM -->

                            <div class="message user">

                                <small>[23:02PM]</small>

                                <span>kadu:</span>

                                <p>

                                    esqueceu o notebook ligado

                                </p>

                            </div>



                            <!-- MENSAGEM -->

                            <div class="message emily">

                                <small>[23:09PM]</small>

                                <span>emily:</span>

                                <p>

                                    tava ouvindo musica 😞

                                </p>

                            </div>



                            <!-- MENSAGEM -->

                            <div class="message user">

                                <small>[02:19AM]</small>

                                <span>kadu:</span>

                                <p>

                                    por 3 horas?

                                </p>

                            </div>



                            <!-- MENSAGEM -->

                            <div class="message emily">

                                <small>[02:30AM]</small>

                                <span>emily:</span>

                                <p>

                                    eu dormi...

                                </p>

                            </div>



                            <!-- SISTEMA -->

                            <div class="message system">

                                <p>

                                    emily is listening to:
                                    "Timmy Bowers"

                                </p>

                            </div>


                        </div>


                    </div>

                </div>


            </div>


            <!-- ===================================== -->
            <!-- DIREITA -->
            <!-- ===================================== -->

            <div class="right-side">


                <!-- ===================================== -->
                <!-- MÚSICA -->
                <!-- ===================================== -->

                <div class="window-box">

                    <div class="box-title">

                        now playing

                    </div>


                    <div class="music-box">

                        <p>

                            Modern Baseball

                        </p>

                        <p class="song-name">

                            Timmy Bowers

                        </p>

                        <audio controls autoplay loop>

                            <source src="/music/song.mp3">

                        </audio>

                    </div>

                </div>



                <!-- ===================================== -->
                <!-- STATUS -->
                <!-- ===================================== -->

                <div class="window-box">

                    <div class="box-title">

                        user status

                    </div>

                    <div class="status-box">

                        <p>last online: 2:37AM</p>

                        <p>status: probably asleep</p>

                        <p>camera feed archived</p>

                        <p>connection: stable</p>

                        <p>cached locally</p>

                    </div>

                </div>



                <!-- ===================================== -->
                <!-- LINKS -->
                <!-- ===================================== -->

                <div class="window-box">

                    <div class="box-title">

                        saved pages

                    </div>

                    <div class="links-box">

                        <a href="#">old photos</a>

                        <a href="#">a7x playlist</a>

                        <a href="#">camera roll</a>

                        <a href="#">last seen</a>

                    </div>

                </div>



                <!-- ===================================== -->
                <!-- UPDATE -->
                <!-- ===================================== -->

                <div class="window-box">

                    <div class="box-title">

                        site info

                    </div>

                    <div class="status-box">

                        <p>last updated: 12/05/2005</p>

                        <p>in her pfp once</p>

                        <p>resolution: 1280x720</p>

                    </div>

                </div>


            </div>


        </div>


    </div>


</body>

</html>